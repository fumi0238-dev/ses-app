generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id                        String     @id @default(uuid())
  status                    String?
  shareable                 String?
  share_note                String?
  added_date                String?
  source                    String?
  project_name_original     String?
  project_name_rewrite      String?
  client_price              String?
  purchase_price            String?
  purchase_price_num        Float?
  role                      String?
  location                  String?
  work_style                String?
  // 構造化フィールド: 単価
  client_price_min          Int?
  client_price_max          Int?
  purchase_price_min        Int?
  purchase_price_max        Int?
  // 構造化フィールド: 働き方
  work_style_category       String?   // フルリモート/リモート併用/オンサイト
  work_style_office_days    String?   // 週○日出社の○
  work_style_initial_onsite    Boolean   @default(false)
  work_style_transition_onsite Boolean   @default(false)
  work_style_note           String?
  period                    String?
  headcount                 String?
  required_skills           String?
  preferred_skills          String?
  required_skill_tags       String?
  preferred_skill_tags      String?
  industry_tags             String?
  required_experience_years Float?
  description_original      String?
  description_rewrite       String?
  age_limit                 String?
  nationality               String?
  english                   String?
  commercial_flow           String?
  interview_count           String?
  created_at                BigInt     @default(0)
  updated_at                BigInt     @default(0)
  deleted                   Boolean    @default(false)
  matchings                 Matching[]

  @@map("projects")
}

model Member {
  id                 String     @id @default(uuid())
  process            String?
  affiliation        String?
  full_name          String?
  initial            String?
  contract_employee  String?
  desired_price      String?
  desired_price_num  Float?
  contact            String?
  desired_position   String?
  skill_sheet_url    String?
  proposal_text      String?
  sales_comment      String?
  skills_summary     String?
  skill_tags         String?
  industry_tags      String?
  experience_years   Float?
  experience_summary String?
  nearest_station    String?
  available_date     String?
  work_preference    String?
  // 構造化フィールド: 共有可否
  shareable                 String?
  share_note                String?
  // 構造化フィールド: 単価
  desired_price_min         Int?
  desired_price_max         Int?
  // 構造化フィールド: 働き方
  work_style_category       String?
  work_style_office_days    String?
  work_style_initial_onsite    Boolean   @default(false)
  work_style_transition_onsite Boolean   @default(false)
  work_style_note           String?
  created_at         BigInt     @default(0)
  updated_at         BigInt     @default(0)
  deleted            Boolean    @default(false)
  matchings          Matching[]

  @@map("members")
}

model Matching {
  id             String  @id @default(uuid())
  project_id     String
  member_id      String
  status         String?
  note           String?
  proposed_date  String?
  interview_date     String?
  primary_assignee   String?
  created_at     BigInt  @default(0)
  updated_at     BigInt  @default(0)
  deleted        Boolean @default(false)
  project        Project @relation(fields: [project_id], references: [id])
  member         Member  @relation(fields: [member_id], references: [id])
  tasks          Task[]

  @@map("matchings")
}

model Task {
  id              String  @id @default(uuid())
  matching_id     String
  content         String?
  done            Boolean @default(false)
  due_date        String?
  sort_order      Int     @default(0)
  progress_status String  @default("未着手")
  progress_note   String?
  assignee        String?
  created_at      BigInt  @default(0)
  updated_at      BigInt  @default(0)
  matching        Matching @relation(fields: [matching_id], references: [id])

  @@map("tasks")
}

model ActivityLog {
  id           String @id @default(uuid())
  action       String?
  target_table String?
  target_id    String?
  target_name  String?
  detail       String?
  timestamp    String?
  user_id      String?
  user_name    String?
  created_at   BigInt @default(0)

  @@map("activity_logs")
}

model Note {
  id           String @id @default(uuid())
  target_table String?
  target_id    String?
  content      String?
  timestamp    String?
  created_at   BigInt @default(0)

  @@map("notes")
}

model User {
  id            String  @id @default(uuid())
  username      String  @unique
  password_hash String
  display_name  String
  role          String  @default("user")
  is_active     Boolean @default(true)
  created_at    BigInt  @default(0)
  updated_at    BigInt  @default(0)

  @@map("users")
}

// ---- Asana-like General Task Management ----

model TaskSection {
  id         String        @id @default(uuid())
  name       String        @default("")
  sort_order Int           @default(0)
  collapsed  Boolean       @default(false)
  created_at BigInt        @default(0)
  updated_at BigInt        @default(0)
  tasks      GeneralTask[]

  @@map("task_sections")
}

model GeneralTask {
  id                 String              @id @default(uuid())
  title              String              @default("")
  description        String              @default("")
  status             String              @default("未着手")
  priority           String              @default("なし")
  assignee           String              @default("")
  due_date           String              @default("")
  sort_order         Int                 @default(0)
  completed_at       BigInt?
  section_id         String?
  parent_id          String?
  linked_project_id  String?
  linked_member_id   String?
  linked_matching_id String?
  created_at         BigInt              @default(0)
  updated_at         BigInt              @default(0)
  deleted            Boolean             @default(false)

  section  TaskSection?      @relation(fields: [section_id], references: [id])
  parent   GeneralTask?      @relation("SubTasks", fields: [parent_id], references: [id])
  children GeneralTask[]     @relation("SubTasks")
  tags     TaskTagAssignment[]
  comments TaskComment[]

  @@map("general_tasks")
}

model TaskTag {
  id         String              @id @default(uuid())
  name       String              @default("")
  color      String              @default("gray")
  created_at BigInt              @default(0)
  tasks      TaskTagAssignment[]

  @@map("task_tags")
}

model TaskTagAssignment {
  id      String      @id @default(uuid())
  task_id String
  tag_id  String
  task    GeneralTask @relation(fields: [task_id], references: [id], onDelete: Cascade)
  tag     TaskTag     @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@unique([task_id, tag_id])
  @@map("task_tag_assignments")
}

model TaskComment {
  id         String      @id @default(uuid())
  task_id    String
  content    String      @default("")
  user_id    String      @default("")
  user_name  String      @default("")
  created_at BigInt      @default(0)
  task       GeneralTask @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("task_comments")
}
